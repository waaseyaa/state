{
    "name": "waaseyaa/state",
    "description": "Key-value state storage for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.3",
        "waaseyaa/database-legacy": "^0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../database-legacy"
        }
    ],
    "autoload": {
        "psr-4": {
            "Waaseyaa\\State\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\State\\Tests\\": "tests/"
        }
    }
}
