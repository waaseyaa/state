{
    "name": "aurora/state",
    "description": "Key-value state storage for Aurora CMS",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.3",
        "aurora/database-legacy": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../database-legacy"
        }
    ],
    "autoload": {
        "psr-4": {
            "Aurora\\State\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aurora\\State\\Tests\\": "tests/"
        }
    }
}
